      },
      "etiquette": {
        "title": "آداب التعامل",
        "tip": "استأذن دائماً قبل تصوير الناس. استخدم يدك اليمنى في الأكل والتحية. قد تؤثر مواعيد رمضان على أوقات الفتح. الجمعة يوم مقدس — كثير من المحلات تُغلق."
      },
      "sites": {
        "title": "التنقل بين المعالم",
        "tip": "احجز تذاكر المواقع مسبقاً عبر الإنترنت للجيزة والأقصر لتجنب الطوابير الطويلة. استعن بمرشدين سياحيين رسميين ومرخصين فقط. بعض المقابر تتطلب تصاريح تصوير."
      }
    },
    "health_tips": {
      "water": {
        "title": "مياه الشرب",
        "tip": "لا تشرب مياه الصنبور أبداً. اشترِ مياهاً معبأة ومختومة فقط. تجنب الثلج في المشروبات من الباعة الجائلين. ماء جوز الهند آمن ومنعش."
      },
      "food": {
        "title": "سلامة الطعام",
        "tip": "تناول الطعام في مطاعم مزدحمة ذات تقييمات جيدة. تجنب السلطات النيئة المغسولة بمياه الصنبور. الطعام الشعبي آمن عادةً إذا طُهي طازجاً وساخناً. تجنب البوفيه المتروك في الحرارة."
      },
      "heat": {
        "title": "الحرارة والشمس",
        "tip": "قد تتخطى درجة الحرارة في مصر 45°C صيفاً. ابقَ رطباً (3 لترات+ يومياً). ارتدِ واقي شمس SPF 50+ وقبعة وملابس قطنية خفيفة. زُر المواقع الخارجية قبل الساعة 10 صباحاً أو بعد 4 مساءً."
      },
      "insects": {
        "title": "الحشرات والزواحف",
        "tip": "استخدم طارد الحشرات، خاصة في دلتا النيل والأقصر صيفاً. توجد عقارب في المناطق الصحراوية — اهزّ حذاءك قبل ارتدائه. تجنب السباحة في النيل."
      },
      "medical": {
        "title": "حقيبة الإسعاف",
        "tip": "احمل: أملاح الإماهة الفموية، أقراص إيقاف الإسهال، مضادات الهيستامين، مضاد حيوي واسع الطيف (بوصفة طبية)، واقي شمس، وأي أدوية موصوفة. التأمين الصحي للسفر ضروري."
      },
      "electricity": {
        "title": "الكهرباء والجهد",
        "tip": "مصر تستخدم 220 فولت/50 هرتز مع قوابس أوروبية مستديرة. احضر محوّلاً عالمياً. قد تحدث انقطاعات في الكهرباء — احمل بطارية محمولة. معظم الفنادق لديها حماة من ارتفاع الجهد."
      }
    }
