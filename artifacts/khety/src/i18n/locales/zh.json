    "tourist_right_label": "旅游权利",
    "health_intro": "强烈建议购买旅行保险。主要旅游区的医院配有英语工作人员。紧急情况请拨打 123。",
    "vaccinations_title": "疫苗与药物",
    "vaccinations_desc": "前往埃及无需强制接种疫苗。建议接种：甲型和乙型肝炎、伤寒、麻腮风三联疫苗及常规疫苗。疟疾风险极低——请咨询医生。请携带处方药物，因为某些品牌在当地可能买不到。",
    "call_label": "拨打",
    "tips": {
      "timing": {
        "title": "最佳游览时间",
        "tip": "10月至4月是理想时期。避免7月至8月——极端高温可达45°C（113°F）。始终携带水并使用 SPF 50+ 防晒霜。"
      },
      "dress": {
        "title": "着装要求",
        "tip": "在清真寺和宗教场所请穿着端庄——遮住肩膀和膝盖。女性应携带头巾。在海滩度假村可穿泳衣。"
      },
      "money": {
        "title": "金钱与砍价",
        "tip": "在市场上砍价是常规。从要价的40-50%开始还价。ATM机分布广泛；随身携带一些小面额埃镑用于小费和街头摊贩。"
      },
      "transport": {
        "title": "出行方式",
        "tip": "使用 Uber 或 Careem 安全出行。乘坐出租车前先商定价格。开罗地铁便宜且高效。避免夜间独自在陌生地区行走。"
      },
      "etiquette": {
        "title": "文化礼仪",
        "tip": "拍摄他人前务必征得同意。饮食和问候时使用右手。斋月期间的时间安排可能影响营业时间。周五是圣日——很多商店关门。"
      },
      "sites": {
        "title": "游览景点",
        "tip": "提前在网上购买吉萨和卢克索的门票，避免长时间排队。仅雇用官方持照导游。部分墓穴内拍照需要许可证。"
      }
    },
    "health_tips": {
      "water": {
        "title": "饮用水",
        "tip": "切勿饮用自来水。只购买密封瓶装水。避免饮用街头小贩饮料中的冰块。椰子水安全可口。"
      },
      "food": {
        "title": "食品安全",
        "tip": "在人气旺、评价好的餐厅就餐。避免食用用自来水清洗的生蔬菜。街头食物如果现做现烫通常安全。避免在高温下放置过久的自助餐。"
      },
      "heat": {
        "title": "高温与日晒",
        "tip": "埃及夏季温度可超过45°C。保持充分水分（每天3升以上）。佩戴 SPF 50+ 防晒霜、遮阳帽和轻薄棉质衣物。上午10点前或下午4点后游览户外景点。"
      },
      "insects": {
        "title": "昆虫与爬行动物",
        "tip": "使用驱虫剂，尤其在夏季的尼罗河三角洲和卢克索。沙漠地区有蝎子——穿鞋前先抖一抖。避免在尼罗河中游泳。"
      },
      "medical": {
        "title": "急救箱",
        "tip": "携带：口服补液盐、止泻药、抗组胺药、广谱抗生素（需处方）、防晒霜及所有处方药。旅行保险必不可少。"
      },
      "electricity": {
        "title": "电力与电压",
        "tip": "埃及使用220V/50Hz，欧式圆形插头。携带万能转换插头。可能停电——随身携带充电宝。大多数酒店配有防浪涌保护器。"
      }
    }
  },
