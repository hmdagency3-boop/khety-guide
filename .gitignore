# ============================================================
# Khety Guide Monorepo — .gitignore
# ============================================================

# ── Build Outputs ────────────────────────────────────────────
dist/
build/
out/
out-tsc/
tmp/
dev-dist/
.output/
*.tsbuildinfo

# Workspace-specific build folders
artifacts/*/dist/
artifacts/*/build/
artifacts/*/dev-dist/
lib/*/dist/
lib/*/build/

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Environment Variables & Secrets ──────────────────────────
.env
.env.*
!.env.example
!.env.template

# ── Vite / PWA cache ─────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*
*.local

# ── Expo / React Native ──────────────────────────────────────
.expo/
.expo-shared/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
testem.log
/libpeerconnection.log

# ── Testing & Coverage ───────────────────────────────────────
/coverage/
.nyc_output/
playwright-report/
test-results/
/typings/

# ── IDEs & Editors ───────────────────────────────────────────
.idea/
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# VSCode (keep shared settings, ignore personal ones)
.vscode/*
!.vscode/extensions.json

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
/.sass-cache
/connect.lock

# ── Cloudflare / Wrangler ────────────────────────────────────
.wrangler/
.dev.vars

# ── Replit (internal tooling — not needed in GitHub) ─────────
.cache/
.local/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
